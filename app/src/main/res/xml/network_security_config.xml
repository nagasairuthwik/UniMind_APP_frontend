<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP to your backend on any IP (e.g. 192.168.x.x or 10.x.x.x). Change BASE_URL in ApiClient.kt to your PC IP from ipconfig. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
