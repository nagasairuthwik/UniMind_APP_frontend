<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Header: Back | AI Chat | Sparkle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="16dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp"
        android:background="@color/screen_background"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/ai_chat_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/signup_back_desc"
            android:src="@drawable/ic_back_arrow_theme" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ai_chat_title"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_sparkle_purple"
            tools:ignore="ContentDescription" />
    </LinearLayout>

    <!-- Chat messages -->
    <ScrollView
        android:id="@+id/ai_chat_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/ai_chat_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI greeting -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:background="@drawable/chat_bubble_ai"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:maxWidth="280dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_chat_greeting"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Message input bar (no file/attach icon) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:background="@color/screen_background"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/chat_input_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <EditText
                android:id="@+id/ai_chat_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="@string/ai_chat_input_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface"
                android:textSize="16sp"
                android:typeface="sans"
                android:imeOptions="actionSend" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/ai_chat_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/ai_chat_mic_desc"
            android:padding="12dp"
            android:src="@drawable/ic_chat_mic" />

        <ImageButton
            android:id="@+id/ai_chat_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/chat_send_btn_bg"
            android:contentDescription="@string/ai_chat_send_desc"
            android:padding="12dp"
            android:src="@drawable/ic_chat_send"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Bottom nav: Home | Insights | Analytics | Settings | Chatbot (selected) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/home_card_white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/ai_chat_nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_home"
                android:textColor="@color/home_nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ai_chat_nav_insights"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_insights" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_insights"
                android:textColor="@color/home_nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ai_chat_nav_analytics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_analytics" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_analytics"
                android:textColor="@color/home_nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ai_chat_nav_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_settings" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_settings"
                android:textColor="@color/home_nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ai_chat_nav_chatbot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@drawable/home_nav_indicator"
                android:layout_marginBottom="2dp" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_chat_selected" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_chatbot"
                android:textColor="@color/home_nav_selected"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
