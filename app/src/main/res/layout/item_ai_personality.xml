<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ai_personality_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/ai_personality_card_unselected"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:elevation="2dp">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/ai_personality_icon_bg">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_welcome_brain"
            tools:ignore="ContentDescription" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/ai_personality_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/signup_title"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/ai_personality_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/signup_subtitle"
            android:textSize="14sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ai_personality_check"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@null"
        android:visibility="gone"
        android:src="@drawable/ic_check_circle"
        tools:ignore="ContentDescription"
        tools:visibility="visible" />
</LinearLayout>
