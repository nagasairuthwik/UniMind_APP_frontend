        <LinearLayout
            android:id="@+id/analytics_nav_analytics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@drawable/home_nav_indicator"
                android:layout_marginBottom="2dp" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_analytics" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_analytics"
                android:textColor="@color/home_nav_selected"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/analytics_nav_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_settings" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_settings"
                android:textColor="@color/home_nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/analytics_nav_chatbot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_chat" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_nav_chatbot"
                android:textColor="@color/home_nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
