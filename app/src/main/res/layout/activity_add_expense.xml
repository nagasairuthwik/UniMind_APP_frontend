<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/add_expense_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/signup_back_desc"
        android:src="@drawable/ic_back_arrow_theme" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/finance_add_expense"
        android:textColor="@color/signup_label"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/add_expense_amount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:hint="Amount spent"
        android:inputType="numberDecimal"
        android:padding="16dp" />

    <EditText
        android:id="@+id/add_expense_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Note (optional)"
        android:inputType="text"
        android:minLines="2"
        android:padding="16dp" />

    <Button
        android:id="@+id/add_expense_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Save expense"
        android:textSize="16sp" />
</LinearLayout>
