<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/signup_background"
    android:orientation="vertical"
    android:paddingTop="32dp">

    <!-- Header: Back | Forgot Password | Menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="16dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/forgot_password_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/signup_back_desc"
            android:src="@drawable/ic_back_arrow_theme" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/forgot_password_title"
            android:textColor="@color/signup_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/forgot_password_menu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/signup_menu_desc"
            android:src="@drawable/ic_more_vert" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forgot_password_heading"
                android:textColor="@color/signup_title"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/forgot_password_instruction"
                android:textColor="@color/signup_subtitle"
                android:textSize="15sp" />

            <!-- Email Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/signup_email"
                android:textColor="@color/signup_label"
                android:textSize="14sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/signup_input_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_email_outline"
                    tools:ignore="ContentDescription" />
                <EditText
                    android:id="@+id/forgot_password_email"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:hint="@string/forgot_password_email_hint"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:importantForAutofill="yes"
                    android:autofillHints="emailAddress"
                    android:textColor="@color/signup_title"
                    android:textColorHint="@color/signup_hint"
                    android:textSize="16sp"
                    android:typeface="sans" />
            </LinearLayout>

            <!-- OTP + New password fields (hidden until OTP sent) -->
            <LinearLayout
                android:id="@+id/forgot_password_otp_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_otp_label"
                    android:textColor="@color/signup_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/forgot_password_otp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/signup_input_background"
                    android:gravity="center_vertical"
                    android:hint="@string/forgot_password_otp_hint"
                    android:inputType="number"
                    android:maxLines="1"
                    android:textColor="@color/signup_title"
                    android:textColorHint="@color/signup_hint"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/forgot_password_new_pass_label"
                    android:textColor="@color/signup_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/forgot_password_new_pass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/signup_input_background"
                    android:gravity="center_vertical"
                    android:hint="@string/forgot_password_new_pass_hint"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/signup_title"
                    android:textColorHint="@color/signup_hint"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/forgot_password_confirm_pass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/signup_input_background"
                    android:gravity="center_vertical"
                    android:hint="@string/forgot_password_confirm_pass_hint"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/signup_title"
                    android:textColorHint="@color/signup_hint"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Send OTP / Reset Password button (gradient + arrow) -->
            <LinearLayout
                android:id="@+id/forgot_password_send_link"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/btn_get_started"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/forgot_password_send_link_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_send_otp"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_forward"
                    tools:ignore="ContentDescription" />
            </LinearLayout>

            <!-- Back to Sign In -->
            <TextView
                android:id="@+id/forgot_password_back_to_signin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:text="@string/forgot_password_back_to_signin"
                android:textColor="@color/sign_in_link"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
