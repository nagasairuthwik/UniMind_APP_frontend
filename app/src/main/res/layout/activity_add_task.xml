<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/add_task_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/signup_back_desc"
        android:src="@drawable/ic_back_arrow_theme" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/productivity_plan_tasks"
        android:textColor="@color/signup_label"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/add_task_title"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:hint="Task name"
        android:inputType="text"
        android:padding="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Remind at"
        android:textColor="@color/signup_label"
        android:textSize="14sp" />

    <Button
        android:id="@+id/add_task_pick_time"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="Pick time" />

    <Button
        android:id="@+id/add_task_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Save &amp; remind"
        android:textSize="16sp" />
</LinearLayout>
