<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/steps_modal_bg">

            <!-- Header: gradient, title, close X -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tasks_header_gradient"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/tasks_overview_title"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/tasks_overview_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/steps_close_circle_theme"
                    android:contentDescription="@string/notification_dismiss_desc"
                    android:padding="8dp"
                    android:src="@drawable/ic_close_overview"
                    android:scaleType="centerInside"
                    android:minWidth="40dp"
                    android:minHeight="40dp" />
            </LinearLayout>

            <!-- Summary: briefcase + 12/15 + Tasks Done (same gradient) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tasks_header_gradient"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_domain_productivity"
                    tools:ignore="ContentDescription" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tasks_overview_value_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tasks_overview_value"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tasks_overview_tasks_done"
                        android:textColor="#E0FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Statistics grid (white) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/screen_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/steps_metric_card_bg"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tasks_metric_completed_today"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tasks_metric_completed_today_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tasks_metric_completed_today_value"
                            android:textColor="@color/signup_label"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/steps_metric_card_bg"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tasks_metric_remaining"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tasks_metric_remaining_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tasks_metric_remaining_value"
                            android:textColor="@color/signup_label"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/steps_metric_card_bg"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tasks_metric_total_planned"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tasks_metric_total_planned_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tasks_metric_total_planned_value"
                            android:textColor="@color/signup_label"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/steps_metric_card_bg"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tasks_metric_completion_rate"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tasks_metric_completion_rate_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tasks_metric_completion_rate_value"
                            android:textColor="@color/signup_label"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/steps_metric_card_bg"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tasks_metric_high_priority"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tasks_metric_high_priority_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tasks_metric_high_priority_value"
                            android:textColor="@color/signup_label"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/steps_metric_card_bg"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tasks_metric_avg_time"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tasks_metric_avg_time_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tasks_metric_avg_time_value"
                            android:textColor="@color/signup_label"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Weekly Trend -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/tasks_weekly_trend"
                    android:textColor="@color/signup_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <!-- Mon -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_mon"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_mon"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Tue -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_tue"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_tue"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Wed -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_wed"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_wed"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Thu -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_thu"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_thu"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Fri -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_fri"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_fri"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Sat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_sat"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_sat"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Sun -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">
                        <View
                            android:id="@+id/tasks_bar_sun"
                            android:layout_width="24dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/tasks_week_bar_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/steps_day_sun"
                            android:textColor="@color/signup_subtitle"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- AI Tip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/steps_ai_tip_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_steps_lightbulb"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="@string/tasks_ai_tip"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Close button -->
            <Button
                android:id="@+id/tasks_overview_close_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/steps_close_btn_bg"
                android:text="@string/steps_close"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
