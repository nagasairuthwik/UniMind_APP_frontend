<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/savings_goal_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:background="@drawable/savings_goal_card_bg"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/card_goal_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/signup_label"
            android:textSize="16sp"
            android:textStyle="bold" />
        <ImageButton
            android:id="@+id/card_goal_view"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:src="@drawable/ic_goal_visibility" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/card_goal_saved_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/signup_label"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="/"
            android:textColor="@color/signup_subtitle"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/card_goal_target_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="@color/signup_subtitle"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">
        <View
            android:id="@+id/card_goal_progress_fill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/savings_goal_progress_fill"
            android:minWidth="4dp" />
        <View
            android:id="@+id/card_goal_progress_track"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="99"
            android:background="@drawable/savings_goal_progress_track" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/card_goal_pct_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FF4CAF50"
            android:textSize="13sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/card_goal_due_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due: —"
            android:textColor="@color/signup_subtitle"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
