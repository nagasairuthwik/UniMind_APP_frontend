<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/signup_background"
    android:orientation="vertical"
    android:paddingTop="32dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="16dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/forgot_password_new_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/signup_back_desc"
            android:src="@drawable/ic_back_arrow_theme" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/forgot_password_title"
            android:textColor="@color/signup_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forgot_password_heading"
            android:textColor="@color/signup_title"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/forgot_password_new_pass_label"
            android:textColor="@color/signup_label"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/forgot_password_new_pass_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/signup_input_background"
            android:gravity="center_vertical"
            android:hint="@string/forgot_password_new_pass_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:textColor="@color/signup_title"
            android:textColorHint="@color/signup_hint"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/forgot_password_confirm_pass_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/signup_input_background"
            android:gravity="center_vertical"
            android:hint="@string/forgot_password_confirm_pass_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:textColor="@color/signup_title"
            android:textColorHint="@color/signup_hint"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/forgot_password_reset_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/btn_get_started"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forgot_password_reset_password"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

